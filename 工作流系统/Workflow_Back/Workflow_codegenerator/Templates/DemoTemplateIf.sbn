namespace Workflow_Back.Models
{
    /// <summary>
    /// 用户模型
    /// </summary>
    public class User
    {
        // 主键映射
        //public int {{filed1}} { get; set; }
        // scriban循环取值

        {{- for templateobject in templateobjects -}}
            {{- if templateobject.username =="UserName1" -}}
            public string {{templateobject.username}} { get; set; }
            {{- else -}}
            public string YDT{{templateobject.username}} { get; set; }
            {{- end -}}
            public string {{templateobject.password}} { get; set; }
        {{- end -}}
    }
}
